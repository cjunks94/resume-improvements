{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe"],
    "chromeLaunchConfig": {
      "args": [
        "--no-sandbox",
        "--disable-setuid-sandbox",
        "--disable-web-security",
        "--disable-gpu",
        "--disable-dev-shm-usage"
      ]
    },
    "timeout": 120000,
    "wait": 2000,
    "ignore": ["color-contrast"]
  },
  "urls": [
    {
      "url": "http://localhost:8000/",
      "screenCapture": "screenshots/home.png",
      "hideElements": "#radar, #village-canvas"
    }
  ]
}
