{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe"],
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-setuid-sandbox", "--disable-web-security", "--disable-features=NetworkService"]
    },
    "timeout": 60000,
    "wait": 5000,
    "hideElements": "#village-canvas, #radar",
    "useIncognitoPage": false
  },
  "urls": [
    {
      "url": "http://localhost:8000/index.html",
      "screenCapture": "screenshots/home.png",
      "hideElements": "#radar"
    }
  ]
}
