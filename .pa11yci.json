{
  "defaults": {
    "standard": "WCAG2AA",
    "runners": ["axe"],
    "chromeLaunchConfig": {
      "args": ["--no-sandbox", "--disable-setuid-sandbox", "--disable-web-security"]
    },
    "timeout": 60000,
    "wait": 5000,
    "ignore": ["color-contrast"]
  },
  "urls": [
    {
      "url": "http://localhost:8000/",
      "screenCapture": "screenshots/home.png",
      "hideElements": "#radar, #village-canvas"
    }
  ]
}
